RewriteEngine On
RewriteCond %{HTTPS} off [OR]
RewriteCond %{HTTP_HOST} ^smartwandler\.de$ [NC]
RewriteRule ^(.*)$ https://www.smartwandler.de/$1 [R=301,L]

# ─────────────────────────────────────────
# Clean URLs für Landingpages (ohne .html-Endung)
# ─────────────────────────────────────────
# 1) Wenn jemand /<slug>.html aufruft → 301-Redirect auf /<slug>
RewriteCond %{THE_REQUEST} \s/+ingenieurbueros\.html[\s?] [NC]
RewriteRule ^ /ingenieurbueros [R=301,L]

RewriteCond %{THE_REQUEST} \s/+lokale-ki\.html[\s?] [NC]
RewriteRule ^ /lokale-ki [R=301,L]

RewriteCond %{THE_REQUEST} \s/+meeting-transkription\.html[\s?] [NC]
RewriteRule ^ /meeting-transkription [R=301,L]

RewriteCond %{THE_REQUEST} \s/+voicemail\.html[\s?] [NC]
RewriteRule ^ /voicemail [R=301,L]

# 2) Intern /<slug> → /<slug>.html ausliefern (URL bleibt sauber)
RewriteRule ^ingenieurbueros/?$ ingenieurbueros.html [L]
RewriteRule ^lokale-ki/?$ lokale-ki.html [L]
RewriteRule ^meeting-transkription/?$ meeting-transkription.html [L]
RewriteRule ^voicemail/?$ voicemail.html [L]

# ─────────────────────────────────────────
# MIME-Types (sicherstellen, dass WebP/WOFF2 korrekt ausgeliefert werden)
# ─────────────────────────────────────────
<IfModule mod_mime.c>
  AddType image/webp .webp
  AddType image/avif .avif
  AddType font/woff2 .woff2
  AddType text/css .css
  AddType application/javascript .js
</IfModule>

# ─────────────────────────────────────────
# Caching (Cache-Control via mod_headers + Expires-Fallback)
# ─────────────────────────────────────────
<IfModule mod_expires.c>
  ExpiresActive On

  # HTML kurz cachen, damit Inhaltsänderungen schnell durchschlagen
  ExpiresByType text/html "access plus 1 hour"

  # Statische Assets ein Jahr cachen (immutable, da bei Updates Dateinamen ggf. geändert werden)
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/avif "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
  ExpiresByType application/font-woff2 "access plus 1 year"
</IfModule>

<IfModule mod_headers.c>
  # Statische Dateien: 1 Jahr + immutable
  <FilesMatch "\.(css|js|png|jpe?g|webp|avif|svg|ico|woff2?|ttf|eot)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # HTML: 1 Stunde, muss revalidiert werden
  <FilesMatch "\.html?$">
    Header set Cache-Control "public, max-age=3600, must-revalidate"
  </FilesMatch>
</IfModule>

# ─────────────────────────────────────────
# Kompression
# ─────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/plain text/xml application/javascript application/json image/svg+xml font/woff2
</IfModule>
